# Entorno general del servicio
PR_REVISOR_ENV=development
PR_REVISOR_HOST=127.0.0.1
PR_REVISOR_PORT=8001

# Directorios de runtime y base de datos
PR_REVISOR_DATA_DIR=data
PR_REVISOR_VAR_DIR=var
PR_REVISOR_DB_PATH=data/reviewer.db

# Archivo de configuración principal de repositorios
PR_REVISOR_REPOS_CONFIG=config/repos.yaml

# Logging y concurrencia de workers
PR_REVISOR_LOG_LEVEL=INFO
PR_REVISOR_WORKER_CONCURRENCY=1

# Secretos por repositorio (referenciados desde config/repos.yaml)
BB_DEMO_WEBHOOK_SECRET=reemplazar-por-secreto
BB_DEMO_API_TOKEN=reemplazar-por-token
